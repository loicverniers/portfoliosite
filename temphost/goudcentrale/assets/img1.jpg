.single-page .item-body, .blog-page .item-body {
    float: none;
}

.single-page .item-info + .item-body, .blog-page .item-info + .item-body {
    width: 78%;
    margin-left: auto;
    margin-right: auto;
}

.single-page .item-info, .blog-page .item-info {
    float: none;
    margin: 0px 0 0 0;
    width: 26%;
}

.single-page .item-content, .blog-page .item-content {
    max-width: 100%;
}

a:hover {
    color: #A67D4E !important;
}

#gkLogo img {
  max-width: 400px;
}
#gkTopInfo {
    border-bottom: 0px;
}

#gkHeaderNav .gkMainMenu .gkmenu > li > span {
    padding: 12px 0px;
}

#gkHeaderNav .gkMainMenu .gkmenu.level0 > li > a.active,
#gkHeaderNav .gkMainMenu .gkmenu.level0 > li > span.active {
  border-bottom: 1px solid #A67D4E;
}

