    color: #A67D4E;
}

hr {
  border-top: 1px solid #A67D4E;
  width: 80px;
}

.item-body ul li:before {
display: none;  
}

/* remove underline */
.single-page .item-body a,
.blog-page .item-body a {
  border-bottom: 0px;
}

/* ALIGN IMAGES NAMES */
.uk-panel-title {
    TEXT-ALIGN: center;
}

/* VERWIJDER li bollen in menu */
#gkHeaderNav .gkmenu.level0 > li:before {
display: none;
}

